NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string. Add the database name before the query string.
# Example format:
# mongodb+srv://<username>:<password>@<cluster-host>/mport?retryWrites=true&w=majority&appName=mport
MONGODB_URI=

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Cloudinary document uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=otli-documents

# CORS
# Comma-separated frontend URLs. Example: http://localhost:5173,https://your-client.vercel.app
CLIENT_ORIGINS=http://localhost:5173

# First locked super admin account for seeding
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@otli.local
SUPER_ADMIN_PASSWORD=ChangeMe123!

# Email OTP for client registration
# Brevo SMTP example:
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-smtp-login
# SMTP_PASS=your-brevo-smtp-key
# MAIL_FROM="OTLI Logistics <no-reply@yourdomain.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
EMAIL_OTP_EXPIRES_MINUTES=10
EMAIL_OTP_MAX_ATTEMPTS=5
EMAIL_OTP_RESEND_SECONDS=60

# Local development only. If SMTP is not configured, the OTP prints in server console.
EMAIL_OTP_DEV_MODE=true

# Pre-advice auto validation fallback values.
# The admin Validation Rules module now stores these in MongoDB.
# These env values are only used as defaults or seed values.
BLACKLISTED_CONTAINERS=
OUTSTANDING_CHARGE_CONTAINERS=
CONTAINER_OWNERSHIP_PREFIXES=MSCU=MSC,MAEU=MAERSK,ONEY=ONE
DEFAULT_GATE_APPOINTMENT_WINDOW=08:00-17:00
